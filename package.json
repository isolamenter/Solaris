{
  "name": "solaris",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20.19" },
  "scripts": {
    "dev": "npm run build && NODE_ENV=production tsx src/server/main.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/server/main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.44.5",
    "fastify": "^5.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}
